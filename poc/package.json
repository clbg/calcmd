{
  "name": "@calcmd/root",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @calcmd/core build",
    "dev": "pnpm --filter @calcmd/core build && pnpm --parallel --filter @calcmd/core --filter @calcmd/website dev",
