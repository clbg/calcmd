{
  "name": "@calcmd/core",
  "version": "0.1.0",
  "description": "CalcMD core parser and evaluator",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "test": "jest",
    "dev": "tsc --watch -p tsconfig.esm.json"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  },
  "keywords": [
    "calcmd",
    "markdown",
    "table",
    "formula"
  ],
  "author": "CalcMD Team",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
