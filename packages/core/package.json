{
  "name": "@calcmd/core",
  "version": "0.2.0",
  "description": "Verifiable calculations in markdown tables - Rust/WASM implementation of CalcMD",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "pkg",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:wasm": "$HOME/.cargo/bin/wasm-pack build --target bundler --out-dir pkg || wasm-pack build --target bundler --out-dir pkg",
    "build:wrapper": "tsup && tsc --emitDeclarationOnly --noEmit false",
    "build": "npm run build:wasm && npm run build:wrapper",
    "test": "node tests/basic.test.mjs",
    "dev": "tsup --watch"
  },
  "keywords": [
    "calcmd",
    "markdown",
    "table",
    "formula",
    "calculator",
    "wasm",
    "webassembly",
    "rust"
  ],
  "author": "CalcMD Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clbg/calcmd.git",
    "directory": "packages/core"
  },
  "homepage": "https://clbg.github.io/calcmd/",
  "bugs": {
    "url": "https://github.com/clbg/calcmd/issues"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "type": "module"
}
