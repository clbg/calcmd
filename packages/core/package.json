{
  "name": "@calcmd/core",
  "version": "0.1.0",
  "description": "Verifiable calculations in markdown tables - parser and evaluator for CalcMD specification",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "test": "jest",
    "dev": "tsc --watch -p tsconfig.esm.json",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    }
  },
  "keywords": [
    "calcmd",
    "markdown",
    "table",
    "formula",
    "calculator",
    "spreadsheet",
    "ai",
    "llm",
    "verifiable",
    "calculations",
    "parser",
    "evaluator"
  ],
  "author": "CalcMD Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clbg/calcmd.git",
    "directory": "packages/core"
  },
  "homepage": "https://clbg.github.io/calcmd/",
  "bugs": {
    "url": "https://github.com/clbg/calcmd/issues"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.0.0",
    "typescript": "^6.0.2"
  }
}
