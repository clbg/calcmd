{
  "name": "@calcmd/wasm",
  "version": "0.1.0",
  "description": "CalcMD WebAssembly implementation - verifiable calculations in markdown tables",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:wasm": "$HOME/.cargo/bin/wasm-pack build --target web --out-dir pkg || wasm-pack build --target web --out-dir pkg",
    "build:wrapper": "tsup",
    "build": "npm run build:wasm && npm run build:wrapper",
    "test": "npm run test:all",
    "test:unit": "node tests/unit.test.mjs",
    "test:compare": "node tests/compare.test.mjs",
    "test:core": "node tests/all-core-tests.mjs",
    "test:all": "bash run-all-tests.sh"
  },
  "keywords": [
    "calcmd",
    "markdown",
    "table",
    "formula",
    "calculator",
    "spreadsheet",
    "wasm",
    "webassembly",
    "assemblyscript"
  ],
  "author": "CalcMD Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clbg/calcmd.git",
    "directory": "packages/wasm"
  },
  "homepage": "https://clbg.github.io/calcmd/",
  "bugs": {
    "url": "https://github.com/clbg/calcmd/issues"
  },
  "devDependencies": {
    "@calcmd/core": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "type": "module"
}