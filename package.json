{
  "name": "@calcmd/root",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "eslint packages/",
    "format": "prettier --write 'packages/**/*.{ts,tsx}'",
    "build:website": "turbo build --filter=@calcmd/website",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "packages/wasm/assembly/**/*.ts": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.21",
    "typescript-eslint": "^8.57.2"
  }
}
